              "name": "Example response",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"grand_prix_name\": \"Monaco Grand Prix\",\n    \"location\": \"Monte Carlo\",\n    \"race_date\": \"2026-05-24\",\n    \"circuit_name\": \"Circuit de Monaco\",\n    \"winner_driver\": null,\n    \"winner_driver_name\": null,\n    \"laps\": 78\n  }\n]"
