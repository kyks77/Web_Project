{
  "info": {
    "name": "F1Hub API Collection",
    "_postman_id": "1e3b63f4-6f0c-48a8-91ea-c2c6d36f1hub",
    "description": "Postman collection for the F1 Hub Angular + Django REST ticket project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "ticketId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"demo12345\"\n}"
            },
            "url": "{{baseUrl}}/auth/login/"
          },
          "response": [
            {
              "name": "Example response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"access\": \"<jwt_access_token>\",\n  \"refresh\": \"<jwt_refresh_token>\",\n  \"username\": \"demo\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/logout/"
          },
          "response": [
            {
              "name": "Example response",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"detail\": \"Logged out successfully.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Teams",
      "item": [
        {
          "name": "Get Teams",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/teams/"
          },
          "response": [
            {
              "name": "Example response",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"name\": \"Red Bull Racing\",\n    \"country\": \"Austria\",\n    \"principal\": \"Christian Horner\",\n    \"car_name\": \"RB20\",\n    \"created_at\": \"2026-04-20T09:00:00Z\"\n  }\n]"
            }
          ]
        }
      ]
    },
    {
